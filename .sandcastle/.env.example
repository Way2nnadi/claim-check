# Copy to `.sandcastle/.env` and fill in values before `npm run agent:run`.
#
# Codex: Sandcastle mounts ~/.codex into Docker, but macOS ChatGPT tokens often
# fail inside the Linux sandbox (401 / refresh_token_invalidated). Set a fresh
# access token here so the orchestrator runs `codex login --with-access-token`
# on the host and again inside each sandbox before agent work starts.
#
# Optional: override the access token read from ~/.codex/auth.json after `codex login`.
# Sandcastle uses it to run `codex login --with-access-token` on the host and inside
# each Docker sandbox before agent work starts.
CODEX_ACCESS_TOKEN=
#
# GitHub: main.mts runs `gh auth token` on the host (using your `gh auth login`
# session) and injects the result into the Docker sandbox as GH_TOKEN.
# Set this only to override that behavior.
GH_TOKEN=
