{
	"name": "claim-check-agent",
	"private": true,
	"type": "module",
	"scripts": {
		"agent:build": "sandcastle docker build-image --image-name sandcastle:claim-check",
		"preagent:run": "npm run agent:build",
		"agent:run": "tsx .sandcastle/main.mts",
		"client:dev": "npm --prefix client run dev",
		"client:build": "npm --prefix client run build",
		"client:test": "npm --prefix client run test"
	},
	"devDependencies": {
		"@ai-hero/sandcastle": "latest",
		"@types/node": "^26.0.0",
		"tsx": "^4.19.0"
	}
}
